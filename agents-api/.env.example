# ==========================
# MICROSAAS — AGENTS API
# ==========================

# Porta da API de agentes
PORT=3001

# Gemini API Key (Google AI Studio → https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=SUA_CHAVE_GEMINI_AQUI

# Ollama (roda localmente na VPS — padrão porta 11434)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# Segredo para rotas internas (gere um UUID aleatório)
API_SECRET=seu_segredo_aqui

# CORS — domínio do seu site Next.js
ALLOWED_ORIGIN=https://seudominio.com
